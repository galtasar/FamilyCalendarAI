# Copy this file to .env and fill in your values
# Never commit .env to source control

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Gmail / Google Calendar OAuth (same credentials for both)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=your-refresh-token

# Email address that receives review notifications and weekly summary
APP_EMAIL=dahl.aicalendar@gmail.com

# Public URL of your server (used in review notification links)
# On Oracle Cloud: http://<your-public-ip>
APP_BASE_URL=http://your-server-ip

# Family password for the web app login screen
APP_PASSWORD=change-me-to-a-strong-password

# Secret for signing JWT tokens (any long random string, e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin API key (choose any strong random string)
ADMIN_KEY=change-me-to-a-strong-random-string

# PostgreSQL password (optional, defaults to 'postgres')
POSTGRES_PASSWORD=change-me-to-a-strong-password
